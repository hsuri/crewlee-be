# Copy to .env and fill in values

PORT=8001

# Postgres connection string
# Local dev:  postgres://postgres:postgres@localhost:5432/crewlee
# Cloud Run:  set via deploy.sh (Cloud SQL socket URL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crewlee

# Admin panel password
ADMIN_PASSWORD=change-me-in-production

# Comma-separated list of allowed frontend origins (for CORS)
# Local dev:  http://localhost:3000
# Production: https://crewlee-<hash>-uc.a.run.app (set automatically by deploy.sh)
ALLOWED_ORIGINS=http://localhost:3000

# RAG knowledge base: Voyage AI (embeddings) and Anthropic (answer generation)
VOYAGE_API_KEY=change-me
ANTHROPIC_API_KEY=change-me
