# Copy to .env and fill in values

PORT=8001

# Leave unset for local dev (demo data seeds normally). Set to "production" to skip the
# fake users/shifts/announcements in app/db/seed.py -- set automatically by cloudbuild.yaml
# for the real Cloud Run deploy, so you should never need to set this yourself.
# ENVIRONMENT=production

# Postgres connection string
# Local dev:  postgres://postgres:postgres@localhost:5432/crewlee
# Cloud Run:  set via deploy.sh (Cloud SQL socket URL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crewlee

# Admin panel password
ADMIN_PASSWORD=change-me-in-production

# Comma-separated list of allowed frontend origins (for CORS)
# Local dev:  http://localhost:3000
# Production: https://crewlee-<hash>-uc.a.run.app (set automatically by deploy.sh)
ALLOWED_ORIGINS=http://localhost:3000

# RAG knowledge base: Voyage AI (embeddings) and Anthropic (answer generation)
VOYAGE_API_KEY=change-me
ANTHROPIC_API_KEY=change-me

# RAG knowledge base: GCS bucket that holds the original uploaded PDF/DOCX files.
# Local dev:  crewlee-rag-docs-local (auth via your own `gcloud auth application-default login`)
# Cloud Run:  crewlee-rag-docs (set automatically by deploy.sh; runs as the service's own SA)
RAG_BUCKET_NAME=crewlee-rag-docs-local
# Local dev only -- points at the ADC file docker-compose.yml mounts into the container.
# Not needed/used on Cloud Run, which authenticates via its attached service account instead.
GOOGLE_APPLICATION_CREDENTIALS=/tmp/gcloud-adc.json
